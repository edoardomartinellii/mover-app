{
  "expo": {
    "name": "Mover",
    "slug": "mover-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "mover",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#003DA5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mover.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Mover utilizza la tua posizione per mostrarti i parcheggi vicini."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#003DA5"
      },
      "package": "com.mover.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ]
    ]
  }
}
